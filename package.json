{
  "name": "octoclean",
  "version": "0.2.0",
  "description": "Code quality analysis for JS/TS repos — dashboard for humans, structured feed for agents. Pairs with pi autoresearch for automated fixing.",
  "type": "module",
  "bin": {
    "codehealth": "./bin/codehealth.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "dev": "tsx src/cli/index.ts",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "express": "^4.18.3",
    "glob": "^10.3.10",
    "js-yaml": "^4.1.0",
    "open": "^10.1.0",
    "ora": "^8.0.1",
    "semver": "^7.6.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.5",
    "@types/semver": "^7.5.6",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  },
  "peerDependencies": {
    "jscpd": "^3.5.10",
    "madge": "^6.1.0",
    "ts-unused-exports": "^10.0.1"
  },
  "peerDependenciesMeta": {
    "jscpd": { "optional": true },
    "madge": { "optional": true },
    "ts-unused-exports": { "optional": true }
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": ["code-quality", "metrics", "static-analysis", "llm", "cli"],
  "license": "MIT"
}
